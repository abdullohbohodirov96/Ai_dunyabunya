# ─── OpenAI API ────────────────────────────────────
# https://platform.openai.com/api-keys dan oling
OPENAI_API_KEY=sk-your-openai-api-key-here

# ─── Telegram Bot ──────────────────────────────────
# @BotFather orqali bot yarating va tokenni oling
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIjKlMnOpQrStUvWxYz

# ─── Telegram Chat ID ─────────────────────────────
# Guruh yoki kanal ID si (masalan: -1001234567890)
# @userinfobot yoki @getidsbot orqali bilib oling
TELEGRAM_CHAT_ID=-1001234567890

# ─── amoCRM subdomain ─────────────────────────────
# amoCRM URL ingizdan oldin keladi: https://SUBDOMAIN.amocrm.ru
AMOCRM_SUBDOMAIN=dunyabunya
